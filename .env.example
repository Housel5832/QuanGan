# 当前使用的厂商（dashscope | kimi | openai）
LLM_PROVIDER=dashscope

# 百炼（DashScope / 默认）
DASHSCOPE_API_KEY=your_dashscope_key_here
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-plus

# Kimi（Moonshot 开放平台，来自 platform.moonshot.cn）
KIMI_API_KEY=your_moonshot_key_here
# KIMI_MODEL=kimi-k2.5

# Kimi Code（订阅制，来自 kimi.com/code，以 sk-kimi- 开头）
KIMI_CODE_API_KEY=your_kimi_code_key_here
# KIMI_CODE_MODEL=kimi-for-coding

# OpenAI
# OPENAI_API_KEY=your_openai_key_here
# OPENAI_MODEL=gpt-4o
